<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_root">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar (insets applied in code) -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:orientation="vertical"
            android:background="@drawable/bg_toolbar_glass"
            android:elevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp">

                <ImageButton android:id="@+id/btnBack"
                    android:layout_width="42dp" android:layout_height="42dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_icon_btn"
                    android:enabled="false" android:alpha="0.3"
                    android:scaleType="center" android:contentDescription="Back"/>

                <ImageButton android:id="@+id/btnForward"
                    android:layout_width="42dp" android:layout_height="42dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:background="@drawable/bg_icon_btn"
                    android:enabled="false" android:alpha="0.3"
                    android:scaleType="center" android:contentDescription="Forward"
                    android:layout_marginStart="2dp"/>

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/bg_url_bar_v2"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp" android:paddingEnd="6dp">

                    <ImageView android:id="@+id/ivSecure"
                        android:layout_width="15dp" android:layout_height="15dp"
                        android:src="@drawable/ic_lock" android:alpha="0.5"
                        android:layout_marginEnd="4dp"/>

                    <EditText android:id="@+id/etUrl"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null" android:inputType="textUri"
                        android:imeOptions="actionGo|flagNoExtractUi"
                        android:singleLine="true" android:textSize="14sp"
                        android:textColor="@color/text_primary" android:hint="Tìm kiếm hoặc nhập URL"
                        android:textColorHint="@color/text_muted" android:selectAllOnFocus="true"/>

                    <ImageButton android:id="@+id/btnRefresh"
                        android:layout_width="30dp" android:layout_height="30dp"
                        android:src="@drawable/ic_refresh"
                        android:background="@null" android:alpha="0.7"
                        android:scaleType="center" android:contentDescription="Reload"/>
                </LinearLayout>

                <ImageButton android:id="@+id/btnDesktop"
                    android:layout_width="42dp" android:layout_height="42dp"
                    android:src="@drawable/ic_home"
                    android:background="@drawable/bg_icon_btn"
                    android:alpha="0.5"
                    android:scaleType="center" android:contentDescription="Desktop"/>

                <ImageButton android:id="@+id/btnBookmark"
                    android:layout_width="42dp" android:layout_height="42dp"
                    android:src="@drawable/ic_bookmark"
                    android:background="@drawable/bg_icon_btn"
                    android:scaleType="center" android:contentDescription="Bookmark"/>

            </LinearLayout>
        </LinearLayout>

        <!-- F2: Tab strip -->
        <HorizontalScrollView
            android:id="@+id/tabScrollView"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@color/bg_browser"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/tabStrip"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"/>

        </HorizontalScrollView>

        <!-- Progress -->
        <ProgressBar android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="3dp"
            android:max="100" android:progressTint="@color/accent_green"
            android:progressBackgroundTint="@color/surface2" android:visibility="gone"/>

        <!-- SwipeRefresh + WebView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <WebView android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"/>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnDevTools"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end" android:layout_margin="16dp"
        android:text="Stream Lab" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFF"
        app:icon="@drawable/ic_devtools" app:iconTint="#FFF"
        app:backgroundTint="@color/accent_green" app:elevation="12dp"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnExportHtml"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|start" android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:text="Xuất HTML" android:textSize="12sp" android:textColor="#FFF"
        app:icon="@drawable/ic_devtools" app:iconTint="#FFF"
        app:backgroundTint="@color/accent_blue" app:elevation="8dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnPickerFloat"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|start" android:layout_margin="16dp"
        android:src="@drawable/ic_picker" android:contentDescription="Picker"
        app:backgroundTint="@color/accent_pink" app:tint="#FFF"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
