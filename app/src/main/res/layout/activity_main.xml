<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar (insets applied in code) -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:orientation="vertical"
            android:background="#141414"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="4dp">

                <ImageButton android:id="@+id/btnBack"
                    android:layout_width="38dp" android:layout_height="38dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_icon_btn"
                    android:enabled="false" android:alpha="0.3"
                    android:scaleType="center" android:contentDescription="Back"/>

                <ImageButton android:id="@+id/btnForward"
                    android:layout_width="38dp" android:layout_height="38dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:background="@drawable/bg_icon_btn"
                    android:enabled="false" android:alpha="0.3"
                    android:scaleType="center" android:contentDescription="Forward"
                    android:layout_marginStart="2dp"/>

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_url_bar_v2"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp" android:paddingEnd="2dp">

                    <ImageView android:id="@+id/ivSecure"
                        android:layout_width="13dp" android:layout_height="13dp"
                        android:src="@drawable/ic_lock" android:alpha="0.5"
                        android:layout_marginEnd="4dp"/>

                    <EditText android:id="@+id/etUrl"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null" android:inputType="textUri"
                        android:imeOptions="actionGo|flagNoExtractUi"
                        android:singleLine="true" android:textSize="11.5sp"
                        android:textColor="#E0E0E0" android:hint="Tìm kiếm hoặc nhập URL"
                        android:textColorHint="#555" android:selectAllOnFocus="true"/>

                    <ImageButton android:id="@+id/btnRefresh"
                        android:layout_width="30dp" android:layout_height="30dp"
                        android:src="@drawable/ic_refresh"
                        android:background="@null" android:alpha="0.7"
                        android:scaleType="center" android:contentDescription="Reload"/>
                </LinearLayout>

                <ImageButton android:id="@+id/btnDesktop"
                    android:layout_width="38dp" android:layout_height="38dp"
                    android:src="@drawable/ic_home"
                    android:background="@drawable/bg_icon_btn"
                    android:alpha="0.5"
                    android:scaleType="center" android:contentDescription="Desktop"/>

                <ImageButton android:id="@+id/btnBookmark"
                    android:layout_width="38dp" android:layout_height="38dp"
                    android:src="@drawable/ic_bookmark"
                    android:background="@drawable/bg_icon_btn"
                    android:scaleType="center" android:contentDescription="Bookmark"/>

            </LinearLayout>
        </LinearLayout>

        <!-- F2: Tab strip -->
        <HorizontalScrollView
            android:id="@+id/tabScrollView"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="#0F0F0F"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/tabStrip"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="4dp"/>

        </HorizontalScrollView>

        <!-- Progress -->
        <ProgressBar android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="2dp"
            android:max="100" android:progressTint="#1D9E75"
            android:progressBackgroundTint="#1A1A1A" android:visibility="gone"/>

        <!-- SwipeRefresh + WebView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <WebView android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"/>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnDevTools"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end" android:layout_margin="16dp"
        android:text="DevTools" android:textSize="12sp" android:textColor="#FFF"
        app:icon="@drawable/ic_devtools" app:iconTint="#FFF"
        app:backgroundTint="#1D9E75" app:elevation="8dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnPickerFloat"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|start" android:layout_margin="16dp"
        android:src="@drawable/ic_picker" android:contentDescription="Picker"
        app:backgroundTint="#E24B4A" app:tint="#FFF"
        app:elevation="8dp" android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
