<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.StreamBrowser" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <!-- Transparent bars — insets handled in code -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/bg_browser</item>
        <!-- Android 15+ edge-to-edge: allow code to manage insets -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">false</item>
    </style>
</resources>
